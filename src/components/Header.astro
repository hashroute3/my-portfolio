---
const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/research/', label: 'Research' },
  { href: '/publications/', label: 'Publications' },
  { href: '/give-back/', label: 'Give Back' },
  { href: '/#projects', label: 'Projects' },
];
const secondaryItem = { href: '/ai/', label: 'AI' };
---

<header class="sticky top-0 z-50 border-b border-surface-800/80 bg-surface-950/90 backdrop-blur-sm">
  <nav
    class="mx-auto flex max-w-3xl flex-wrap items-center justify-end gap-x-4 gap-y-2 px-4 py-4 sm:gap-x-6 sm:px-6"
    aria-label="Main navigation"
  >
    <ul class="flex flex-wrap items-center justify-end gap-x-4 gap-y-2 sm:gap-x-6">
      {navItems.map((item) => {
        const isExternal = item.href.startsWith('http') || item.href.startsWith('#');
        const isHome = item.href === '/';
        const isActive = isHome
          ? currentPath === '/'
          : !isExternal && (currentPath === item.href || currentPath.startsWith(item.href));
        return (
          <li>
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium transition-colors',
                isActive ? 'text-sky-400' : 'text-surface-400 hover:text-surface-100',
              ]}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
    <a
      href={secondaryItem.href}
      class:list={[
        'rounded-full border px-3 py-1 text-sm font-medium transition-colors',
        currentPath === secondaryItem.href || currentPath.startsWith(secondaryItem.href)
          ? 'border-sky-400/60 text-sky-400'
          : 'border-surface-700 text-surface-400 hover:border-surface-500 hover:text-surface-100',
      ]}
    >
      {secondaryItem.label}
    </a>
  </nav>
</header>
