---
import BaseLayout from '../../layouts/BaseLayout.astro';

const committees = [
  {
    role: 'Technical Program Committee Member',
    organization: 'PEARC26 — Practice & Experience in Advanced Research Computing',
    url: 'https://pearc.acm.org/pearc26/',
    body: 'ACM',
    year: '2026',
    description:
      'Reviewing and selecting technical submissions for one of the leading conferences on advanced research computing infrastructure, software, and applications.',
  },
  {
    role: 'Technical Committee Member',
    organization: 'Security and Privacy in Consumer Technology (SPC) — IEEE CTSOC',
    url: 'https://ctsoc.ieee.org/technical/technical-committees/spc-tc?view=article&id=312:spc-tc-members&catid=21',
    body: 'IEEE',
    year: 'Present',
    description:
      "Contributing to the IEEE Consumer Technology Society's technical committee focused on security and privacy challenges in consumer-facing technology.",
  },
];

const communityPlaceholder = [
  {
    title: 'Community initiatives',
    body:
      'Add highlights of meetups, local chapters, or volunteer teaching — replace this placeholder with your own entries.',
  },
];

const hackathonPlaceholder = [
  {
    title: 'Hackathons & build events',
    body: 'List events you organized, mentored at, or won — placeholder entry.',
  },
];

const mentorshipPlaceholder = [
  {
    title: 'Mentorship',
    body: 'Career or technical mentorship (e.g. programs, recurring office hours) — placeholder entry.',
  },
];

const ossPlaceholder = [
  {
    title: 'Open-source contributions',
    body: 'Notable OSS projects, maintainership, or sustained contributions — placeholder entry. Link to GitHub as needed.',
  },
];
---

<BaseLayout
  title="Give Back"
  description="Mahendran Vasagam — community work, mentorship, program committees, hackathons, and open-source contributions."
>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <header>
      <h1 class="font-serif text-3xl font-semibold text-surface-50">Give Back</h1>
      <p class="mt-2 text-surface-400">
        Ways I contribute outside day-to-day work — community programs, events, mentorship, reviewing,
        and open source. For formal publications, see{' '}
        <a href="/publications/" class="text-sky-400 hover:underline">Publications</a>.
      </p>
    </header>

    <section class="mt-12" aria-labelledby="community-heading">
      <h2 id="community-heading" class="font-serif text-xl font-semibold text-surface-100">
        Community work
      </h2>
      <ul class="mt-6 space-y-4" role="list">
        {communityPlaceholder.map((item) => (
          <li class="rounded-xl border border-dashed border-surface-700 bg-surface-900/30 p-6">
            <h3 class="font-medium text-surface-200">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-surface-400">{item.body}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12" aria-labelledby="hackathons-heading">
      <h2 id="hackathons-heading" class="font-serif text-xl font-semibold text-surface-100">
        Hackathons
      </h2>
      <ul class="mt-6 space-y-4" role="list">
        {hackathonPlaceholder.map((item) => (
          <li class="rounded-xl border border-dashed border-surface-700 bg-surface-900/30 p-6">
            <h3 class="font-medium text-surface-200">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-surface-400">{item.body}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12" aria-labelledby="mentorship-heading">
      <h2 id="mentorship-heading" class="font-serif text-xl font-semibold text-surface-100">
        Mentorship
      </h2>
      <ul class="mt-6 space-y-4" role="list">
        {mentorshipPlaceholder.map((item) => (
          <li class="rounded-xl border border-dashed border-surface-700 bg-surface-900/30 p-6">
            <h3 class="font-medium text-surface-200">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-surface-400">{item.body}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12" aria-labelledby="committees-heading">
      <h2 id="committees-heading" class="font-serif text-xl font-semibold text-surface-100">
        Judging, program committees & SME roles
      </h2>

      <ul class="mt-6 space-y-6" role="list">
        {committees.map((item) => (
          <li class="rounded-xl border border-surface-800 bg-surface-900/50 p-6 transition-colors hover:border-surface-700">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <span class="rounded bg-surface-800 px-2 py-0.5 text-xs font-medium text-sky-400">
                    {item.body}
                  </span>
                  <span class="text-xs text-surface-500">{item.year}</span>
                </div>
                <h3 class="mt-2 font-serif text-lg font-semibold text-surface-50">{item.role}</h3>
                <p class="mt-1 text-sm text-surface-400">{item.organization}</p>
                <p class="mt-3 text-sm leading-relaxed text-surface-400">{item.description}</p>
              </div>
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="shrink-0 text-sm text-sky-400 hover:underline"
              >
                Learn more ↗
              </a>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12" aria-labelledby="oss-heading">
      <h2 id="oss-heading" class="font-serif text-xl font-semibold text-surface-100">
        Open-source contributions
      </h2>
      <ul class="mt-6 space-y-4" role="list">
        {ossPlaceholder.map((item) => (
          <li class="rounded-xl border border-dashed border-surface-700 bg-surface-900/30 p-6">
            <h3 class="font-medium text-surface-200">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-surface-400">{item.body}</p>
          </li>
        ))}
      </ul>
    </section>
  </article>
</BaseLayout>
