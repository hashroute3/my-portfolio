---
import BaseLayout from '../../layouts/BaseLayout.astro';

const journalArticles = [
  {
    title: 'Ensuring Security in Modern Data Pipelines: Practical Strategies for Data Engineers',
    authors: 'Mahendran Vasagam',
    journal: 'International Journal of Intelligent Systems and Applications in Engineering',
    year: '2024',
    url: 'https://doi.org/10.17762/ijisae.v12i22s.8090',
  },
  {
    title: 'Devops Lifecycle Management And Cloud Migration Assessments: A Security-Driven CICD Perspective',
    authors: 'Ramesh Krishna Mahimalur, Mahendran Vasagam, Devi Manoharan',
    journal: 'Journal of International Crisis and Risk Communication Research',
    year: '2024',
    url: 'https://doi.org/10.63278/jicrcr.vi.3670',
  },
  {
    title: 'From Assessment to Automation: DevOps Lifecycle Management for Secure Cloud Migration and CICD Implementation.',
    authors: 'Ramesh Krishna Mahimalur, Mahendran Vasagam, Devi Manoharan',
    journal: 'Power System Technology',
    year: '2026',
    url: 'https://doi.org/10.5281/zenodo.18639741',
  },
  {
    title: 'Learning Execution Plan Embeddings for Multi-Dimensional Query Resource Prediction',
    authors: 'Mahendran Vasagam, Ashok Kumar, Anshul Garg',
    journal: 'IEEE Access',
    year: '2026',
    url: 'https://doi.org/10.1109/access.2026.3670242',
  },
];

const committees = [
  {
    role: 'Technical Program Committee Member',
    organization: 'PEARC26 — Practice & Experience in Advanced Research Computing',
    url: 'https://pearc.acm.org/pearc26/',
    body: 'ACM',
    year: '2026',
    description:
      'Reviewing and selecting technical submissions for one of the leading conferences on advanced research computing infrastructure, software, and applications.',
  },
  {
    role: 'Technical Committee Member',
    organization: 'Security and Privacy in Consumer Technology (SPC) — IEEE CTSOC',
    url: 'https://ctsoc.ieee.org/technical/technical-committees/spc-tc?view=article&id=312:spc-tc-members&catid=21',
    body: 'IEEE',
    year: 'Present',
    description:
      "Contributing to the IEEE Consumer Technology Society's technical committee focused on security and privacy challenges in consumer-facing technology.",
  },
];
---

<BaseLayout
  title="Give Back"
  description="Mahendran Vasagam's contributions back to the community — technical program committees, standards bodies, and academic service."
>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <header>
      <h1 class="font-serif text-3xl font-semibold text-surface-50">Give Back</h1>
      <p class="mt-2 text-surface-400">
        Ways I contribute to the broader technical community — reviewing research, shaping standards,
        and helping grow the field.
      </p>
    </header>

    <section class="mt-12" aria-labelledby="committees-heading">
      <h2 id="committees-heading" class="font-serif text-xl font-semibold text-surface-100">
        Program & Technical Committees
      </h2>

      <ul class="mt-6 space-y-6" role="list">
        {committees.map((item) => (
          <li class="rounded-xl border border-surface-800 bg-surface-900/50 p-6 transition-colors hover:border-surface-700">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <span class="rounded bg-surface-800 px-2 py-0.5 text-xs font-medium text-sky-400">
                    {item.body}
                  </span>
                  <span class="text-xs text-surface-500">{item.year}</span>
                </div>
                <h3 class="mt-2 font-serif text-lg font-semibold text-surface-50">{item.role}</h3>
                <p class="mt-1 text-sm text-surface-400">{item.organization}</p>
                <p class="mt-3 text-sm leading-relaxed text-surface-400">{item.description}</p>
              </div>
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="shrink-0 text-sm text-sky-400 hover:underline"
              >
                Learn more ↗
              </a>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-16" aria-labelledby="journal-articles-heading">
      <h2 id="journal-articles-heading" class="font-serif text-xl font-semibold text-surface-100">
        Journal Articles
      </h2>
      <p class="mt-2 text-surface-400">
        Selected peer-reviewed publications. Each entry links to the official landing page.
      </p>

      <ol class="mt-6 space-y-4" role="list">
        {journalArticles.map((paper) => (
          <li class="rounded-xl border border-surface-800 bg-surface-900/50 p-6">
            <p class="text-sm text-surface-300">
              <span class="font-medium text-surface-200">{paper.authors}</span>
              <span class="text-surface-500"> ({paper.year}). </span>
              <a href={paper.url} target="_blank" rel="noopener noreferrer" class="text-sky-400 hover:underline">
                {paper.title}
              </a>
              <span class="text-surface-500">. </span>
              <span class="italic text-surface-400">{paper.journal}</span>
              <span class="text-surface-500">. </span>
              <a href={paper.url} target="_blank" rel="noopener noreferrer" class="text-surface-400 hover:underline">
                {paper.url}
              </a>
            </p>
          </li>
        ))}
      </ol>
    </section>
  </article>
</BaseLayout>
