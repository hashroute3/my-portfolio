---
import BaseLayout from '../../layouts/BaseLayout.astro';

const committees = [
  {
    role: 'IEEE Senior Member',
    organization: 'Institute of Electrical and Electronics Engineers (IEEE)',
    url: 'https://www.ieee.org/membership/senior/',
    body: 'IEEE',
    description:
      'Senior Member grade recognizing sustained professional achievement, significant performance, and peer-reviewed elevation within IEEE.',
  },
  {
    role: 'Technical Committee Member',
    organization: 'Security and Privacy in Consumer Technology (SPC) — IEEE Consumer Technology Society',
    url: 'https://ctsoc.ieee.org/technical/technical-committees/spc-tc?view=article&id=312:spc-tc-members&catid=21',
    body: 'IEEE CTSoc',
    description:
      'Active technical committee member contributing to the security and privacy agenda for consumer technology research and practice.',
  },
  {
    role: 'Technical Committee Member',
    organization: 'ICCE-Taiwan 2026 — IEEE International Conference on Consumer Electronics',
    url: 'https://icce-taiwan.org/2026/',
    body: 'IEEE',
    description:
      'Serving on the technical committee for IEEE ICCE-Taiwan, supporting review and program quality for consumer electronics research.',
  },
  {
    role: 'Professional Member',
    organization: 'Association for Computing Machinery (ACM)',
    url: 'https://www.acm.org/membership',
    body: 'ACM',
    description:
      'Active professional member of ACM, supporting the advancement of computing as a science and profession.',
  },
  {
    role: 'Technical Committee Member',
    organization: 'PEARC 2026 — Practice and Experience in Advanced Research Computing',
    url: 'https://pearc.acm.org/pearc26/',
    body: 'ACM',
    description:
      'Contributing to the technical program committee for PEARC 2026, reviewing work in advanced research computing infrastructure, software, and applications.',
  },
  {
    role: 'Technical Committee Member',
    organization: 'CHI 2026 — ACM Human-Computer Interaction',
    url: 'https://chi2026.acm.org/',
    body: 'ACM',
    description:
      'Serving on the technical committee for CHI 2026, supporting peer review and program development for the HCI community.',
  },
  {
    role: 'Technical Program Committee Member',
    organization: 'EuroSciPy 2026 — European Conference on Python in Science',
    url: 'https://www.euroscipy.org/',
    body: 'EuroSciPy',
    description:
      'Supporting the technical program committee for EuroSciPy 2026, focused on scientific computing and the Python ecosystem.',
  },
  {
    role: 'Working Group Participant',
    organization: 'Cloud Security Alliance (CSA) — AI Safety Working Group',
    url: 'https://cloudsecurityalliance.org/',
    body: 'CSA',
    description:
      'Active member contributing to discussions and community work around AI safety, security, and responsible adoption.',
  },
];

---

<BaseLayout
  title="Give Back"
  description="Mahendran Vasagam — community work, mentorship, program committees, hackathons, and open-source contributions."
>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <header>
      <h1 class="font-serif text-3xl font-semibold text-surface-50">Give Back</h1>
      <p class="mt-2 text-surface-400">
        Ways I contribute outside day-to-day work — community programs, events, mentorship, reviewing,
        and open source. For formal publications, see{' '}
        <a href="/publications/" class="text-sky-400 hover:underline">Publications</a>.
      </p>
    </header>

    <section class="mt-12" aria-labelledby="committees-heading">
      <h2 id="committees-heading" class="font-serif text-xl font-semibold text-surface-100">
        Judging, program committees & SME roles
      </h2>

      <ul class="mt-6 space-y-6" role="list">
        {committees.map((item) => (
          <li class="rounded-xl border border-surface-800 bg-surface-900/50 p-6 transition-colors hover:border-surface-700">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <span class="rounded bg-surface-800 px-2 py-0.5 text-xs font-medium text-sky-400">
                    {item.body}
                  </span>
                </div>
                <h3 class="mt-2 font-serif text-lg font-semibold text-surface-50">{item.role}</h3>
                <p class="mt-1 text-sm text-surface-400">{item.organization}</p>
                <p class="mt-3 text-sm leading-relaxed text-surface-400">{item.description}</p>
              </div>
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="shrink-0 text-sm text-sky-400 hover:underline"
              >
                Learn more ↗
              </a>
            </div>
          </li>
        ))}
      </ul>
    </section>
  </article>
</BaseLayout>
