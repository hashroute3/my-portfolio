---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScholarlyPublication from '../../components/ScholarlyPublication.astro';
import { getAllPublications, journalArticles, preprintsAndTechnical } from '../../data/publications';
import { academicProfiles } from '../../data/profile';
import { publicationsItemListJsonLd } from '../../lib/publicationMetadata';

const pageTitle = 'Publications | Mahendran Vasagam';
const description =
  'Peer-reviewed journal articles, conference papers, and preprints by Mahendran Vasagam — with DOI, BibTeX, and structured metadata for academic discovery.';

const site = Astro.site ?? new URL('https://mahendranvasagam.com');
const itemListLd = publicationsItemListJsonLd(getAllPublications(), site);
---

<BaseLayout title={pageTitle} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(itemListLd)} />
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <header>
      <h1 class="font-serif text-3xl font-semibold text-surface-50">Publications</h1>
      <p class="mt-2 max-w-2xl text-surface-400">
        Selected journal articles, conference papers, and technical writing by Mahendran Vasagam.
      </p>
      <nav class="mt-6 overflow-x-auto pb-1" aria-label="Publication sections">
        <ul class="flex min-w-max gap-3 text-sm text-surface-400">
          <li>
            <a href="#journal-heading" class="rounded-full border border-surface-800 px-3 py-1.5 hover:border-surface-700 hover:text-surface-100">
              Journal Articles
            </a>
          </li>
          <li>
            <a href="#preprint-heading" class="rounded-full border border-surface-800 px-3 py-1.5 hover:border-surface-700 hover:text-surface-100">
              Preprints / Technical Articles
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <section class="mt-10" aria-labelledby="academic-profiles-heading">
      <h2 id="academic-profiles-heading" class="font-serif text-xl font-semibold text-surface-100">
        Academic Profiles
      </h2>
      <p class="mt-2 text-sm text-surface-500">
        Cross-links that help academic crawlers, citation systems, and AI discovery tools connect
        authorship across sources.
      </p>
      <ul class="mt-6 grid gap-4 sm:grid-cols-3" role="list">
        {academicProfiles.map((profile) => (
          <li class="rounded-xl border border-surface-800 bg-surface-900/50 p-5">
            <h3 class="font-medium text-surface-100">{profile.label}</h3>
            <p class="mt-2 text-sm leading-relaxed text-surface-400">{profile.description}</p>
            <a
              href={profile.href}
              class="mt-4 inline-flex text-sm text-sky-400 hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              {profile.placeholder ? `Add ${profile.label} link` : `View ${profile.label} profile`}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-14" aria-labelledby="journal-heading">
      <h2 id="journal-heading" class="font-serif text-xl font-semibold text-surface-100">
        Journal Articles
      </h2>
      <p class="mt-2 text-sm text-surface-500">
        Peer-reviewed journal articles.
      </p>
      <div class="mt-8 flex flex-col gap-8">
        {journalArticles.map((pub) => (
          <ScholarlyPublication publication={pub} />
        ))}
      </div>
    </section>

    <section class="mt-16" aria-labelledby="preprint-heading">
      <h2 id="preprint-heading" class="font-serif text-xl font-semibold text-surface-100">
        Preprints / Technical Articles
      </h2>
      <p class="mt-2 text-sm text-surface-500">
        Preprints, technical reports, and non-journal technical writing.
      </p>
      <div class="mt-8 flex flex-col gap-8">
        {preprintsAndTechnical.map((pub) => (
          <ScholarlyPublication publication={pub} />
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
